{
  "name": "zenno",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' lint",
    "db:generate": "pnpm --filter @zenno/db db:generate",
    "db:migrate": "pnpm --filter @zenno/db db:migrate",
    "db:studio": "pnpm --filter @zenno/db db:studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  }
}
